extends baseEmail

block content
  p Hi #{firstName},
  p You requested a password reset. Click the button below to reset your password.
  p This token is valid for only 10 minutes.
  table.btn.btn-primary(role='presentation', border='0', cellpadding='0', cellspacing='0')
    tbody
      tr
        td(align='left')
          table(role='presentation', border='0', cellpadding='0', cellspacing='0')
            tbody
              tr
                td
                  a(href=`${url}`, target='_blank') Reset Password
  p If you did not request this, please ignore this email.
  p - OrderIt Team